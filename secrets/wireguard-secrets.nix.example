# WireGuard wg0 secrets (Nix attrset).
# Copy to wireguard-secrets.nix in this folder and fill in your values. Do not commit wireguard-secrets.nix.
#   cp wireguard-secrets.nix.example wireguard-secrets.nix
{
  address = [ "10.0.0.2/32" ];
  dns = [ "10.0.0.1" ];
  listenPort = 51820;
  peers = [
    {
      publicKey = "PEER_PUBLIC_KEY_BASE64";
      allowedIPs = [ "0.0.0.0/0" ];
      endpoint = "vpn.example.com:51820";
      persistentKeepalive = 25;
    }
  ];
}
