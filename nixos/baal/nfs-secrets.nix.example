# NFS mount secrets (Nix attrset).
# Copy to nfs-secrets.nix and fill in your values. Do not commit nfs-secrets.nix.
#   cp nfs-secrets.nix.example nfs-secrets.nix
{
  serverPath = "nfs-server.local:/path/to/export";
  mountPoint = "/mnt/mainpool";
  mountOptions = "noatime";
  timeoutIdleSec = "600";
}
